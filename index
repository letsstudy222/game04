<!DOCTYPE html>
<html lang="vi">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Mini Clash Kingdom v0.3 Clean</title>

<style>

*{
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}


body{

    margin:0;
    background:#111;
    overflow:hidden;

}


/* THANH TÀI NGUYÊN */

#topbar{

    height:60px;

    background:#252525;

    display:flex;

    justify-content:center;

    align-items:center;

    gap:20px;

    color:white;

}


.resource{

    background:#444;

    padding:10px 20px;

    border-radius:12px;

    font-size:18px;

}





/* MENU */

#menu{

    height:70px;

    background:#333;

    display:flex;

    justify-content:center;

    align-items:center;

    gap:10px;

}



button{

    padding:10px 15px;

    border:none;

    border-radius:8px;

    background:#eab83e;

    font-weight:bold;

    cursor:pointer;

}


button:hover{

    background:#ffd968;

}




/* CANVAS */


canvas{

    display:block;

    margin:auto;

    background:#70c447;

}





/* BẢNG THÔNG TIN */

#panel{

    position:absolute;

    top:150px;

    left:20px;

    background:#222;

    color:white;

    padding:15px;

    border-radius:10px;

    display:none;

    width:220px;

}


#panel h3{

    margin-top:0;

}



</style>


</head>


<body>



<!-- TÀI NGUYÊN -->

<div id="topbar">


<div class="resource">
🪙 Gold:
<span id="gold">1000</span>
</div>


<div class="resource">
💜 Elixir:
<span id="elixir">1000</span>
</div>


<div class="resource">
👷 Builder:
<span id="builder">1</span>
</div>


</div>




<!-- MENU XÂY DỰNG -->

<div id="menu">


<button onclick="buildMode('mine')">
⛏ Mine (250)
</button>


<button onclick="buildMode('collector')">
💜 Collector (250)
</button>


<button onclick="upgradeBuilding()">
⬆ Upgrade
</button>


<button onclick="cancelAction()">
❌ Cancel
</button>


</div>




<!-- PANEL THÔNG TIN -->


<div id="panel">


<h3 id="buildingName">
Building
</h3>


<p>
Level:
<span id="buildingLevel">
1
</span>
</p>


<p>
HP:
<span id="buildingHP">
100
</span>
</p>


<p>
Upgrade:
<span id="upgradeCost">
200
</span>
Gold
</p>


</div>




<canvas id="game"
width="1000"
height="650">
</canvas>





<script>


// ==========================
// KHỞI TẠO GAME
// ==========================


const canvas =
document.getElementById("game");


const ctx =
canvas.getContext("2d");



const TILE = 50;



const COLS =
canvas.width / TILE;


const ROWS =
canvas.height / TILE;




let gold = 1000;

let elixir = 1000;



let buildings = [];



let selectedBuilding = null;


let currentMode = null;



// Giá xây

const BUILD_PRICE = {

mine:250,

collector:250

};




// ==========================
// CÁC HÀM HIỂN THỊ
// ==========================


function updateUI(){


document.getElementById("gold")
.innerText = gold;


document.getElementById("elixir")
.innerText = elixir;


}





function hidePanel(){

document.getElementById("panel")
.style.display="none";

}



function showPanel(b){


document.getElementById("panel")
.style.display="block";


document.getElementById("buildingLevel")
.innerText=b.level;


document.getElementById("buildingHP")
.innerText=b.hp;


document.getElementById("upgradeCost")
.innerText=b.level*200;



document.getElementById("buildingName")
.innerText=
b.type==="mine"
?
"⛏ Gold Mine"
:
"💜 Elixir Collector";

}
// ==========================
// VẼ BẢN ĐỒ
// ==========================


function drawMap(){


    for(let y=0;y<ROWS;y++){

        for(let x=0;x<COLS;x++){


            ctx.fillStyle =
            (x+y)%2===0
            ?
            "#72c94c"
            :
            "#69bc43";


            ctx.fillRect(
                x*TILE,
                y*TILE,
                TILE,
                TILE
            );


            ctx.strokeStyle =
            "rgba(0,0,0,.05)";


            ctx.strokeRect(
                x*TILE,
                y*TILE,
                TILE,
                TILE
            );


        }

    }

}



// ==========================
// CHỌN CHẾ ĐỘ XÂY
// ==========================


function buildMode(type){

    currentMode = type;

    selectedBuilding=null;

    hidePanel();

}




function cancelAction(){

    currentMode=null;

    selectedBuilding=null;

    hidePanel();

}




// ==========================
// CLICK CANVAS
// ==========================


canvas.onclick=function(e){


    let rect =
    canvas.getBoundingClientRect();


    let mouseX =
    e.clientX - rect.left;


    let mouseY =
    e.clientY - rect.top;



    let x =
    Math.floor(mouseX/TILE)*TILE;


    let y =
    Math.floor(mouseY/TILE)*TILE;



    // chọn công trình


    for(let b of buildings){


        if(
            b.x===x &&
            b.y===y
        ){

            selectedBuilding=b;

            showPanel(b);

            return;

        }

    }




    // xây mới


    if(currentMode){


        let price =
        BUILD_PRICE[currentMode];



        if(gold < price){

            alert("Không đủ Gold");

            return;

        }



        // kiểm tra ô trống


        buildings.push({

            type:currentMode,

            x:x,

            y:y,

            level:1,

            hp:100

        });



        gold -= price;


        updateUI();


        currentMode=null;


    }


};






// ==========================
// NÂNG CẤP
// ==========================


function upgradeBuilding(){


    if(!selectedBuilding){

        return;

    }



    let cost =
    selectedBuilding.level * 200;



    if(gold < cost){

        alert(
        "Cần "+cost+" Gold"
        );

        return;

    }



    gold -= cost;



    selectedBuilding.level++;


    selectedBuilding.hp += 50;



    updateUI();


    showPanel(selectedBuilding);


}






// ==========================
// VẼ CÔNG TRÌNH
// ==========================



function drawBuildings(){


    for(let b of buildings){



        let cx =
        b.x + TILE/2;


        let cy =
        b.y + TILE/2;




        ctx.save();


        ctx.translate(cx,cy);




        // thanh máu


        ctx.fillStyle="#222";


        ctx.fillRect(
            -25,
            -38,
            50,
            7
        );



        ctx.fillStyle="#25d63b";


        ctx.fillRect(
            -25,
            -38,
            Math.min(50,b.hp/6),
            7
        );





        // GOLD MINE


        if(b.type==="mine"){


            ctx.fillStyle="#555";


            ctx.fillRect(
                -22,
                -22,
                44,
                44
            );



            ctx.fillStyle="#ffd900";


            ctx.beginPath();


            ctx.arc(
                0,
                0,
                12,
                0,
                Math.PI*2
            );


            ctx.fill();


        }






        // ELIXIR COLLECTOR


        if(b.type==="collector"){


            ctx.fillStyle="#6038aa";


            ctx.fillRect(
                -20,
                -25,
                40,
                50
            );



            ctx.fillStyle="#e29cff";


            ctx.beginPath();


            ctx.arc(
                0,
                0,
                10,
                0,
                Math.PI*2
            );


            ctx.fill();


        }




        // LEVEL


        ctx.fillStyle="white";


        ctx.font="14px Arial";


        ctx.fillText(
            "Lv."+b.level,
            -15,
            45
        );



        ctx.restore();


    }


}





// ==========================
// GAME LOOP
// ==========================



function gameLoop(){



    ctx.clearRect(
        0,
        0,
        canvas.width,
        canvas.height
    );



    drawMap();


    drawBuildings();



    requestAnimationFrame(gameLoop);


}



gameLoop();







// ==========================
// SINH TÀI NGUYÊN
// ==========================


setInterval(()=>{


    for(let b of buildings){



        if(b.type==="mine"){


            gold +=
            5*b.level;


        }



        if(b.type==="collector"){


            elixir +=
            5*b.level;


        }


    }



    updateUI();



},3000);


</script>


</body>

</html>
